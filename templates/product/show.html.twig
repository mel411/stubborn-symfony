{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
    <style>
        .product-page {
            max-width: 1200px;
            margin: 0 auto;
        }

        .product-box {
            border: 1px solid #999;
            background: #f3f3f3;
            padding: 28px 30px;
            margin-top: 25px;
        }

        .product-layout {
            display: grid;
            grid-template-columns: 520px 1fr;
            gap: 40px;
            align-items: start;
        }

        .product-image-box {
            width: 100%;
            max-width: 520px;
            aspect-ratio: 1 / 1;
            border: 1px solid #999;
            background: #fff;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .product-image-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .product-right {
            padding-top: 18px;
            display: flex;
            flex-direction: column;
            gap: 26px;
            min-height: 100%;
        }

        .product-info-row {
            display: grid;
            grid-template-columns: 70px 160px;
            gap: 14px;
            align-items: start;
        }

        .product-label {
            font-size: 20px;
        }

        .product-value {
            font-size: 24px;
        }

        .product-size-block {
            display: flex;
            flex-direction: column;
            gap: 0px;
            width: 120px;
        }

        .product-size-title {
            border: 1px solid #999;
            border-bottom: 1px solid #999;
            background: #fff;
            text-align: center;
            padding: 6px 8px;
            font-size: 18px;
        }

        .product-size-select {
            width: 120px;
            height: 42px;
            border: 1px solid #999;
            border-top: none;
            background: #fff;
            font-size: 18px;
            padding: 6px;
            box-sizing: border-box;
        }

        .product-action {
            margin-top: 8px;
        }

        .product-btn {
            display: inline-block;
            min-width: 210px;
            text-align: center;
            padding: 12px 18px;
            border: 1px solid #666;
            border-radius: 8px;
            text-decoration: none;
            color: #111;
            background: #f8f8f8;
            cursor: pointer;
            font-size: 18px;
        }

        @media (max-width: 1000px) {
            .product-layout {
                grid-template-columns: 1fr;
            }

            .product-image-box {
                max-width: 100%;
            }
        }
    </style>

    <div class="product-page">
        <div class="product-box">
            <div class="product-layout">
                <div class="product-image-box">
                    <img src="{{ asset('images/' ~ product.image) }}" alt="{{ product.name }}">
                </div>

                <div class="product-right">
                    <div class="product-info-row">
                        <div class="product-label">Nom</div>
                        <div class="product-value">{{ product.name }}</div>
                    </div>

                    <div class="product-info-row">
                        <div class="product-label">Prix</div>
                        <div class="product-value">{{ product.price }} €</div>
                    </div>

                    <form method="post" action="{{ path('app_cart_add', {id: product.id}) }}">
                        <div class="product-size-block">
                            <div class="product-size-title">Taille</div>

                            <select name="size" class="product-size-select" required>
                                {% for stock in product.stocks %}
                                    {% if stock.quantity > 0 %}
                                        <option value="{{ stock.size }}">{{ stock.size }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>

                        <div class="product-action">
                            <button type="submit" class="product-btn">AJOUTER AU PANIER</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}