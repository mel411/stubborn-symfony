<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Stubborn{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f3f3f3;
        color: #111;
    }

    .site-wrapper {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .site-header {
        background: #f3f3f3;
        border-bottom: 1px solid #999;
        padding: 18px 24px 14px 24px;
    }

    .header-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
    }

    .brand-area {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .brand-area img {
        width: 160px;
        height: auto;
        display: block;
    }

    .slogan {
        margin-top: 6px;
        font-size: 14px;
        color: #222;
    }

    .main-nav {
        display: flex;
        gap: 28px;
        align-items: center;
        padding-top: 6px;
        flex-wrap: wrap;
    }

    .main-nav a {
        color: #111;
        text-decoration: none;
        font-size: 15px;
    }

    .main-nav a.active {
        font-weight: bold;
        text-decoration: underline;
    }

    .page-content {
        flex: 1;
        padding: 28px 32px;
    }

    .site-footer {
        border-top: 1px solid #999;
        padding: 18px 30px;
        background: #f3f3f3;
        font-size: 15px;
    }

    .container-wide {
        max-width: 1180px;
        margin: 0 auto;
    }

    .auth-page {
        min-height: 62vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .auth-card {
        width: 100%;
        max-width: 340px;
        border: 1px solid #aaa;
        background: #f3f3f3;
        padding: 14px 12px 18px 12px;
        box-sizing: border-box;
    }

    .auth-title {
        font-size: 20px;
        margin: 0 0 10px 0;
    }

    .auth-separator {
        border: none;
        border-top: 1px solid #cfd8e3;
        margin: 8px 0 14px 0;
    }

    .auth-label {
        display: block;
        font-size: 14px;
        margin-bottom: 6px;
    }

    .auth-input,
    .auth-card input[type="text"],
    .auth-card input[type="email"],
    .auth-card input[type="password"] {
        width: 100%;
        box-sizing: border-box;
        padding: 8px 10px;
        border: 1px solid #999;
        background: #fff;
        margin-bottom: 14px;
        font-size: 14px;
    }

    .auth-button {
        display: inline-block;
        background: #74b9ff;
        color: #fff;
        text-decoration: none;
        border: none;
        border-radius: 6px;
        padding: 10px 16px;
        font-size: 14px;
        cursor: pointer;
    }

    .auth-link {
        color: #6c63ff;
        font-size: 14px;
        text-decoration: underline;
    }

    .auth-block-text {
        font-size: 14px;
        margin: 0 0 8px 0;
    }

    .footer-lines p {
        margin: 4px 0;
    }

    @media (max-width: 900px) {
        .header-inner {
            flex-direction: column;
            align-items: flex-start;
        }

        .main-nav {
            padding-top: 12px;
            gap: 18px;
        }
    }
</style>

        {% block stylesheets %}{% endblock %}
    </head>

    <body>
        <div class="site-wrapper">
            <header class="site-header">
                <div class="container-wide header-inner">
                    <div class="brand-area">
                        <a href="{{ path('app_home') }}">
                            <img src="{{ asset('images/logo.png') }}" alt="Stubborn logo">
                        </a>
                        <div class="slogan"><em>Don't compromise on your look</em></div>
                    </div>

                    <nav class="main-nav">
                        {% if app.user %}
                            <a href="{{ path('app_home') }}"
                               class="{% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">
                                Accueil
                            </a>

                            <a href="{{ path('app_products') }}"
                               class="{% if app.request.attributes.get('_route') == 'app_products' %}active{% endif %}">
                                Boutique
                            </a>

                            <a href="{{ path('app_cart') }}"
                               class="{% if app.request.attributes.get('_route') == 'app_cart' %}active{% endif %}">
                                Panier
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_admin_products') }}"
                                   class="{% if app.request.attributes.get('_route') starts with 'app_admin_products' %}active{% endif %}">
                                    Admin
                                </a>
                            {% endif %}

                            <a href="{{ path('app_logout') }}">
                                Se déconnecter
                            </a>
                        {% else %}
                            <a href="{{ path('app_home') }}"
                               class="{% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">
                                Accueil
                            </a>

                            <a href="{{ path('app_register') }}"
                               class="{% if app.request.attributes.get('_route') == 'app_register' %}active{% endif %}">
                                S'inscrire
                            </a>

                            <a href="{{ path('app_login') }}"
                               class="{% if app.request.attributes.get('_route') == 'app_login' %}active{% endif %}">
                                Se connecter
                            </a>
                        {% endif %}
                    </nav>
                </div>
            </header>

            <main class="page-content">
                <div class="container-wide">
                    {% block body %}{% endblock %}
                </div>
            </main>

           <footer class="site-footer">
                <div class="container-wide">
                    <p><strong>Nom de la société :</strong> Stubborn</p>
                    <p><strong>Adresse :</strong> Piccadilly Circus, London W1J 0DA, Royaume-Uni</p>
                    <p><strong>Adresse de contact :</strong> stubborn@blabla.com</p>
                </div>
            </footer>
        </div>
    </body>
</html>