{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <style>
        .home-featured-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
            margin-top: 26px;
            margin-bottom: 80px;
        }

        .home-product-card {
            border: 1px solid #888;
            background: #f3f3f3;
            padding: 14px 14px 18px 14px;
        }

        .home-product-image-wrap {
            width: 100%;
            aspect-ratio: 1 / 1;
            border: 1px solid #aaa;
            background: #fff;
            overflow: hidden;
            margin-bottom: 16px;
        }

        .home-product-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .home-product-name {
            font-size: 18px;
            margin: 0 0 10px 0;
        }

        .home-product-price {
            font-size: 16px;
            margin: 0 0 16px 0;
        }

        .home-product-link {
            display: inline-block;
            min-width: 92px;
            text-align: center;
            padding: 10px 18px;
            border: 1px solid #666;
            border-radius: 8px;
            background: #f8f8f8;
            color: #111;
            text-decoration: none;
            font-weight: 600;
        }

        .company-box {
            border-top: 1px solid transparent;
            padding-top: 10px;
            font-size: 18px;
            line-height: 1.6;
        }

        @media (max-width: 900px) {
            .home-featured-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <section>
        <div class="home-featured-grid">
            {% for product in products %}
                <div class="home-product-card">
                    <div class="home-product-image-wrap">
                        <img src="{{ asset('images/' ~ product.image) }}" alt="{{ product.name }}">
                    </div>

                    <p class="home-product-name">{{ product.name }}</p>
                    <p class="home-product-price">{{ product.price }} €</p>

                    {% if app.user %}
                        <a class="home-product-link" href="{{ path('app_product_show', {id: product.id}) }}">VOIR</a>
                    {% else %}
                        <span style="display:inline-block; min-width:92px;"></span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}